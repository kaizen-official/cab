DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/drift?retryWrites=true&w=majority"

JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

PORT=4000
NODE_ENV=development

CORS_ORIGIN="http://localhost:3000"

# SMTP (Gmail, SendGrid, Mailgun, etc.) - optional; if unset, OTPs are logged to console
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
MAIL_FROM="drift <noreply@yourdomain.com>"
